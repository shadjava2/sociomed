# Copier en .env.production sur le serveur et remplir. Ne pas committer .env.production.

# URL publique du backend (pour liens PDF, API, etc.)
APP_PUBLIC_BASE_URL=https://api.medical.senat.cd
# URL du frontend (pour QR code page de vérification)
APP_FRONT_BASE_URL=https://medical.senat.cd

# Base de données MySQL
SPRING_DATASOURCE_URL=jdbc:mysql://MYSQL_HOST:3306/senat_courriers_audiences?useSSL=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=secret

# JWT (clé Base64, 32 octets)
JWT_SECRET=votre_cle_base64_32_octets

# Optionnel
# OPENAI_API_KEY=sk-...
