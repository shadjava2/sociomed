	<detail>
		<band height="320">
			<element kind="textField" uuid="17bee7d4-62bc-40cc-83e0-36fb3613f0d4" positionType="Float" x="0" y="0" width="539" height="320" markup="html" fontName="DejaVu Serif" fontSize="11.0" textAdjust="StretchHeight" blankWhenNull="true" hTextAlign="Justified" vTextAlign="Top">
				<paragraph lineSpacing="Proportional" lineSpacingSize="1.35" spacingAfter="10"/>
				<expression><![CDATA["<p><b>NOM &amp; POST-NOMS :</b> "
+ ($P{nom} == null ? "" : $P{nom}) + " "
+ ($P{postnom} == null ? "" : $P{postnom})
+ "</p>"

+ "<p><b>PRENOM :</b> "
+ ($P{prenom} == null ? "" : $P{prenom})
+ "</p>"

+ "<p><b>SEXE :</b> "
+ ($P{genre} == null ? "" : $P{genre})
+ "</p>"

+ "<p><b>AGE :</b> "
+ ($P{age} == null ? "" : $P{age})
+ "</p>"

+ "<p><b>ADRESSE DU MALADE :</b> "
+ (($P{adresseMalade} == null || $P{adresseMalade}.trim().isEmpty()) ? "-" : $P{adresseMalade})
+ "</p>"

+ "<p><b>QUALITE DU MALADE :</b> "
+ (($P{qualiteMalade} == null || $P{qualiteMalade}.trim().isEmpty()) ? "-" : $P{qualiteMalade})
+ "</p>"

+ "<p><b>EST ADRESSE A :</b> "
+ (($P{etablissement} == null || $P{etablissement}.trim().isEmpty()) ? "-" : $P{etablissement})
+ "</p>"

+ "<p><b>MOTIF :</b><br/>"
+ (($P{motif} == null || $P{motif}.trim().isEmpty()) ? "-" : $P{motif}.replace("\r\n", "<br/>").replace("\n", "<br/>"))
+ "</p>"

+ "<br/>"

+ "<p>N.B : Les frais sont à charge du Sénat.</p>"

+ "<br/><br/>"

+ "<p align='right'>Fait à Kinshasa, le <b>"
+ ($P{dateEmission} == null ? "" : $P{dateEmission})
+ "</b>.</p>"

+ "<br/><br/>"

+ "<p align='right'><b>Le Médecin du Sénat</b><br/>"
+ ($P{createdByFullname} == null ? "" : $P{createdByFullname})
+ "</p>"]]></expression>
			</element>
		</band>
	</detail>
