# Copier en .env et remplir les valeurs. Ne pas commiter .env.

# Domaine public (ex: medical.senat.cd) — utilisé par Caddy et pour les URLs dans l'app
DOMAIN=medical.senat.cd

# Base URL publique du backend (liens PDF, vérification, etc.)
APP_PUBLIC_BASE_URL=https://medical.senat.cd/api
# Base URL du frontend (pour les QR codes et liens de vérification)
APP_FRONT_BASE_URL=https://medical.senat.cd

# Base de données MySQL (serveur existant ou conteneur à part)
SPRING_DATASOURCE_URL=jdbc:mysql://MYSQL_HOST:3306/senat_courriers_audiences?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=secret

# JWT (générer une clé Base64 32 octets : openssl rand -base64 32)
JWT_SECRET=votre-cle-base64-32-octets

# JVM production (optionnel) — défaut : 24 Go heap pour 16c/64G (voir docs/production-tuning.md)
# JAVA_OPTS=-Xms2g -Xmx24g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UseStringDeduplication -Djava.security.egd=file:/dev/./urandom

# Tunnel Cloudflare (optionnel, requis si vous lancez avec --profile tunnel)
# Zero Trust > Networks > Tunnels > votre tunnel > obtenir le token
# Ne pas committer le token (rester en .env uniquement)
# CLOUDFLARED_TUNNEL_TOKEN=eyJhIjoi...
