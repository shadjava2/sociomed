# Caddyfile — reverse proxy pour PEC (frontend + backend)
# Image standard caddy:2-alpine (sans plugin realip)
# En prod derrière Cloudflare, l'IP client peut etre lue via X-Forwarded-For / CF-Connecting-IP côté app

:80 {
    # API → backend Spring Boot
    handle_path /api/* {
        reverse_proxy backend:8085 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Tout le reste → frontend (SPA)
    handle {
        reverse_proxy frontend:80
    }
}

# Bloc HTTPS automatique (décommenter et adapter quand DOMAIN est défini)
